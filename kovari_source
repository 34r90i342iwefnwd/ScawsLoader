        task.delay(1.5, function() DiscordButton.Text = "Join Discord" end)
    end))

    -- Animate children in staggered
    task.delay(0.15, function()
        local elements = {InputSection, StatusLabel, ButtonContainer, DiscordSection, FooterLabel}
        for i, el in ipairs(elements) do
            if el and el.Parent then
                local orig = el.Position
                el.Position = UDim2.new(orig.X.Scale, orig.X.Offset, orig.Y.Scale, orig.Y.Offset + 20)
                task.delay(i * 0.06, function()
                    Util.Tween(el, {Position = orig}, 0.35, Enum.EasingStyle.Quart)
                end)
            end
        end
    end)

    return {
        Destroy = function() getgenv().UI_CLOSED = true; Close() end,
        SetStatus = SetStatus
    }
end

