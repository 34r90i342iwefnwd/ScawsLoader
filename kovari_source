-- ANIMATIONS — iOS-inspired spring and fluid animations
-- ═══════════════════════════════════════════════════════════════════
local Animate = {}

function Animate.FadeIn(object, duration, delay)
    delay = delay or 0
    duration = duration or Theme.NormalSpeed
    if object:IsA("GuiObject") then
        local originalTransparency = object:GetAttribute("TargetBgTransparency") or 0
        object.BackgroundTransparency = 1
        task.delay(delay, function()
            Util.Tween(object, {BackgroundTransparency = originalTransparency}, duration)
        end)
    end
end

function Animate.SlideIn(object, direction, duration, delay)
    delay = delay or 0
    duration = duration or Theme.NormalSpeed
    direction = direction or "left"
    if not object:IsA("GuiObject") then return end
    local originalPos = object.Position
    local offsets = {
        left = {-40, 0}, right = {40, 0},
        up = {0, -40}, down = {0, 40}
    }
    local off = offsets[direction] or offsets.left
    local startPos = UDim2.new(originalPos.X.Scale, originalPos.X.Offset + off[1], originalPos.Y.Scale, originalPos.Y.Offset + off[2])
    object.Position = startPos
    task.delay(delay, function()
        Util.Spring(object, {Position = originalPos}, duration)
    end)
end

function Animate.FadeOut(object, duration, callback)
    duration = duration or Theme.NormalSpeed
    if object:IsA("GuiObject") then
        Util.Tween(object, {BackgroundTransparency = 1}, duration)
    end
    for _, child in ipairs(object:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
            Util.Tween(child, {TextTransparency = 1}, duration)
        end
        if child:IsA("ImageLabel") then
            Util.Tween(child, {ImageTransparency = 1}, duration)
        end
        if child:IsA("UIStroke") then
            Util.Tween(child, {Transparency = 1}, duration)
        end
    end
    if callback then task.delay(duration, callback) end
end

