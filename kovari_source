                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Parent = SwitchTrack
            })
            Util.Corner(Knob, 12)
            Util.Shadow(Knob, 2, 0.55)

            -- Subtle knob shine
            local KnobShine = Util.Create("Frame", {
                Size = UDim2.new(1, 0, 0.45, 0),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BackgroundTransparency = 0.85,
                BorderSizePixel = 0,
                Parent = Knob
            })
            Util.Corner(KnobShine, 12)

            local SwitchButton = Util.Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 3,
                Parent = SwitchTrack
            })

            CreateRowDivider(Row)

            table.insert(Connections, SwitchButton.MouseButton1Click:Connect(function()
                state = not state
                -- Track color
                Util.Tween(SwitchTrack, {BackgroundColor3 = state and Theme.Accent or Theme.Fill}, 0.18, Enum.EasingStyle.Sine)
                -- Inner shadow
                Util.Tween(TrackInner, {BackgroundTransparency = state and 1 or 0}, 0.18, Enum.EasingStyle.Sine)
                -- Glow
                Util.Tween(SwitchGlow, {ImageTransparency = state and 0.72 or 1}, 0.18)
                -- Knob slide — iOS spring bounce
                local targetKnobPos = state and UDim2.new(1, -27, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
                Util.Spring(Knob, {Position = targetKnobPos}, 0.22)
