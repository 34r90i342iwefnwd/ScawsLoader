    -- ── Stagger animation for tab sections ──
    local function AnimateElement(element, delay)
        delay = delay or 0
        local originalBgTrans = element.BackgroundTransparency
        local originalPos = element.Position
        local textElements = {}
        for _, child in ipairs(element:GetDescendants()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                table.insert(textElements, {obj = child, original = child.TextTransparency})
            elseif child:IsA("ImageLabel") and child.Name ~= "Shadow" and child.Name ~= "Glow" then
                table.insert(textElements, {obj = child, original = child.ImageTransparency, isImage = true})
            elseif child:IsA("UIStroke") then
                table.insert(textElements, {obj = child, original = child.Transparency, isStroke = true})
            end
        end
        element.BackgroundTransparency = 1
        element.Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset, originalPos.Y.Scale, originalPos.Y.Offset + 18)
        for _, data in ipairs(textElements) do
            if data.isImage then data.obj.ImageTransparency = 1
            elseif data.isStroke then data.obj.Transparency = 1
            else data.obj.TextTransparency = 1 end
        end
        task.delay(delay, function()
            if not element or not element.Parent then return end
            Util.Tween(element, {Position = originalPos}, 0.45, Enum.EasingStyle.Quart)
            Util.Tween(element, {BackgroundTransparency = originalBgTrans}, 0.35, Enum.EasingStyle.Quad)
            for i, data in ipairs(textElements) do
                if data.obj and data.obj.Parent then
                    task.delay(i * 0.012, function()
                        if data.isImage then Util.Tween(data.obj, {ImageTransparency = data.original}, 0.4, Enum.EasingStyle.Quad)
                        elseif data.isStroke then Util.Tween(data.obj, {Transparency = data.original}, 0.4, Enum.EasingStyle.Quad)
                        else Util.Tween(data.obj, {TextTransparency = data.original}, 0.4, Enum.EasingStyle.Quad) end
                    end)
                end
            end
        end)
    end

