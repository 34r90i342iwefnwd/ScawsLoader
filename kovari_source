                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, 0, 0, 40),
                Size = UDim2.new(0, 150, 0, 0),
                BackgroundColor3 = Theme.Elevated,
                ClipsDescendants = true,
                Visible = false,
                ZIndex = 9999,
                Parent = ScreenGui
            })
            Util.Corner(DropdownList, Theme.CornerRadius)
            Util.Stroke(DropdownList, Theme.Border, 1, 0.3)
            Util.Shadow(DropdownList, 8, 0.35)

            Util.Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 1), Parent = DropdownList})
            Util.Padding(DropdownList, 4, 4, 4, 4)

            CreateRowDivider(Row)

            local function CloseDropdown()
                isOpen = false
                Util.Tween(DropdownList, {Size = UDim2.new(0, 150, 0, 0)}, 0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
                Util.Tween(Arrow, {Rotation = 90}, Theme.QuickSpeed)
                task.delay(0.16, function() if not isOpen then DropdownList.Visible = false end end)
            end

            local function OpenDropdown()
                isOpen = true
                local buttonPos = DropButton.AbsolutePosition
                local buttonSize = DropButton.AbsoluteSize
                DropdownList.Position = UDim2.new(0, buttonPos.X + buttonSize.X, 0, buttonPos.Y + buttonSize.Y + 6)
                DropdownList.Visible = true
                local targetHeight = math.min(#options * 30 + 10, 200)
                Util.Spring(DropdownList, {Size = UDim2.new(0, 150, 0, targetHeight)}, 0.22)
                Util.Tween(Arrow, {Rotation = 270}, Theme.QuickSpeed)
            end

            local function PopulateOptions()
                for _, child in ipairs(DropdownList:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end
                for _, option in ipairs(options) do
                    local OptionBtn = Util.Create("TextButton", {
                        Size = UDim2.new(1, 0, 0, 28),
                        BackgroundColor3 = Theme.Fill,
                        BackgroundTransparency = 1,
                        Font = Theme.FontMedium,
                        Text = "  " .. option,
                        TextColor3 = option == selected and Theme.Accent or Theme.TextSecondary,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        AutoButtonColor = false,
                        ZIndex = 10000,
                        Parent = DropdownList
                    })
                    Util.Corner(OptionBtn, 6)

                    -- Checkmark for selected
                    if option == selected then
                        local Check = Util.Create("TextLabel", {
                            AnchorPoint = Vector2.new(1, 0.5),
                            Size = UDim2.new(0, 20, 1, 0),
                            Position = UDim2.new(1, -4, 0.5, 0),
                            BackgroundTransparency = 1,
                            Font = Theme.FontBold,
                            Text = "✓",
                            TextColor3 = Theme.Accent,
                            TextSize = 12,
                            ZIndex = 10001,
                            Parent = OptionBtn
                        })
                    end

                    OptionBtn.MouseEnter:Connect(function()
                        Util.Tween(OptionBtn, {BackgroundTransparency = 0, TextColor3 = Theme.TextPrimary}, Theme.QuickSpeed)
                    end)
                    OptionBtn.MouseLeave:Connect(function()
                        Util.Tween(OptionBtn, {BackgroundTransparency = 1, TextColor3 = option == selected and Theme.Accent or Theme.TextSecondary}, Theme.QuickSpeed)
                    end)
                    OptionBtn.MouseButton1Click:Connect(function()
                        selected = option
                        DropButton.Text = "  " .. selected
                        CloseDropdown()
                        callback(selected)
                    end)
                end
            end
            PopulateOptions()

            table.insert(Connections, DropButton.MouseButton1Click:Connect(function()
                if isOpen then CloseDropdown() else OpenDropdown() end
            end))

            return {
                SetSelected = function(_, newOption) selected = newOption; DropButton.Text = "  " .. selected end,
                Refresh = function(_, newOptions) options = newOptions; PopulateOptions() end
            }
        end

