    -- TAB CREATION — iOS segmented control
    -- ═══════════════════════════════════════════════════════════════
    local function CreateTab(name, layoutOrder, isDefault)
        local tab = {}

        local TabButton = Util.Create("TextButton", {
            Size = UDim2.new(0, 0, 1, 0),
            AutomaticSize = Enum.AutomaticSize.X,
            BackgroundTransparency = 1,
            Font = Theme.FontSemibold,
            Text = "  " .. name .. "  ",
            TextColor3 = Theme.TextTertiary,
            TextSize = 11,
            AutoButtonColor = false,
            LayoutOrder = layoutOrder or 0,
            ZIndex = 2,
            Parent = TabBar
        })
        Util.Corner(TabButton, 6)

        local TabContent = Util.Create("Frame", {
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Visible = false,
            Parent = ContentContainer
        })
        Util.Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 10), Parent = TabContent})

        tab.Button = TabButton
        tab.Content = TabContent
        tab.Name = name
        tab.AnimatedIn = false
        table.insert(AllTabs, tab)

        local function SelectTab()
            if CurrentTab == tab then return end

            -- Deactivate old
            if CurrentTab then
                Util.Tween(CurrentTab.Button, {TextColor3 = Theme.TextTertiary}, Theme.QuickSpeed)
                CurrentTab.Content.Visible = false
                CurrentTab.AnimatedIn = false
            end

            CurrentTab = tab
            Util.Tween(TabButton, {TextColor3 = Theme.TextPrimary}, Theme.QuickSpeed)

            -- Animate tab selector pill behind active tab
            task.defer(function()
                local pos = TabButton.AbsolutePosition
                local size = TabButton.AbsoluteSize
                local barPos = TabBarBg.AbsolutePosition
                Util.Tween(TabSelector, {
                    Position = UDim2.new(0, pos.X - barPos.X, 0.5, -13),
                    Size = UDim2.new(0, size.X, 0, 26)
                }, 0.22, Enum.EasingStyle.Quint)
            end)

            TabContent.Visible = true

            if not tab.AnimatedIn then
                tab.AnimatedIn = true
                local sections = {}
                for _, child in ipairs(TabContent:GetChildren()) do
                    if child:IsA("Frame") then
                        table.insert(sections, child)
                    end
                end
                for i, sect in ipairs(sections) do
                    AnimateElement(sect, i * 0.06)
                end
            end
        end

        table.insert(Connections, TabButton.MouseButton1Click:Connect(SelectTab))
        table.insert(Connections, TabButton.MouseEnter:Connect(function()
            if CurrentTab ~= tab then Util.Tween(TabButton, {TextColor3 = Theme.TextSecondary}, Theme.QuickSpeed) end
        end))
        table.insert(Connections, TabButton.MouseLeave:Connect(function()
            if CurrentTab ~= tab then Util.Tween(TabButton, {TextColor3 = Theme.TextTertiary}, Theme.QuickSpeed) end
        end))

        if isDefault or #AllTabs == 1 then task.defer(SelectTab) end
        return tab
    end

