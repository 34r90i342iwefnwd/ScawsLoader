                end)
                callback(state)
            end))

            return {
                SetState = function(_, newState)
                    state = newState
                    Util.Tween(SwitchTrack, {BackgroundColor3 = state and Theme.Accent or Theme.Fill}, Theme.QuickSpeed)
                    Util.Tween(TrackInner, {BackgroundTransparency = state and 1 or 0}, Theme.QuickSpeed)
                    Util.Tween(SwitchGlow, {ImageTransparency = state and 0.72 or 1}, Theme.QuickSpeed)
                    Knob.Position = state and UDim2.new(1, -27, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
                end
            }
        end

