function Util.FormatDate(timestamp)
    local date = os.date("*t", timestamp)
    local months = {"Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"}
    return string.format("%s %d, %d", months[date.month], date.day, date.year)
end

