function Util.Ripple(button)
    local ripple = Util.Create("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.88,
        ZIndex = button.ZIndex + 1,
        Parent = button
    })
    Util.Corner(ripple, 100)

    local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.5
    Util.Tween(ripple, {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        BackgroundTransparency = 1
    }, 0.55, Enum.EasingStyle.Quad)

    task.delay(0.55, function()
        if ripple and ripple.Parent then ripple:Destroy() end
    end)
end

-- iOS-style press scale effect
function Util.PressEffect(button)
    Util.Tween(button, {Size = UDim2.new(
        button.Size.X.Scale, button.Size.X.Offset - 2,
        button.Size.Y.Scale, button.Size.Y.Offset - 1
    )}, 0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
end

function Util.ReleaseEffect(button, originalSize)
