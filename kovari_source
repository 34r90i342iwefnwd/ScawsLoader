-- ═══════════════════════════════════════════════════════
local JunkieKeySystem = {}

function JunkieKeySystem.new(config)
    local self = setmetatable({}, {__index = JunkieKeySystem})
    self.ApiKey = config.ApiKey or config.api or ""
    self.Service = config.Service or config.service or ""
    self.Provider = config.Provider or config.provider or ""
    self.SDK = nil
    local success, result = pcall(function()
        return loadstring(game:HttpGet("https://junkie-development.de/sdk/JunkieKeySystem.lua"))()
    end)
    if success and result then
        self.SDK = result
    else
        warn("[Kovari] Failed to load Junkie SDK:", result)
    end
    return self
end

function JunkieKeySystem:GetKeyLink()
    if not self.SDK then return false, "Junkie SDK not loaded" end
    local success, link = pcall(function()
        return self.SDK.getLink(self.ApiKey, self.Provider, self.Service)
    end)
    if success and link then return true, link end
    return false, "Failed to get key link"
end

function JunkieKeySystem:CopyLink()
    local success, link = self:GetKeyLink()
    if success then
        pcall(function() (setclipboard or toclipboard or function() end)(link) end)
        return true, "Link copied to clipboard!"
    end
    return false, link or "Failed to copy link"
end

function JunkieKeySystem:VerifyKey(key)
    if not self.SDK then return false, "Junkie SDK not loaded" end
    if not key or key == "" then return false, "Please enter a key" end
    key = key:gsub("%s+", "")
    local success, result = pcall(function()
        return self.SDK.verifyKey(self.ApiKey, key, self.Service)
    end)
    if success and result == true then return true, "Key verified successfully!" end
    return false, "Invalid key. Please try again."
end

